#

data-vg / data-lv - mounted as /mnt/data - holds VM related stuff in /mnt/data/vm

VG        #PV #LV #SN Attr   VSize    VFree   
  data-vg     1   1   0 wz--n-  931.51g  631.51g

 LV        VG        Attr       LSize   Pool Origin Data%  Meta%  Move Log Cpy%Sync Convert
  data-lv   data-vg   -wi-ao---- 300.00g 

/mnt/data/vm
/mnt/data/vm/boot
/mnt/data/vm/images

# ubuntu 26.04

http://cdimage.ubuntu.com/ubuntu/releases/26.04/release/
download and uncompress in /mnt/data/vm/images
unxz ubuntu-26.04-preinstalled-server-amd64.img.xz

create /mnt/isoimage

sudo mount -o loop /mnt/data/vm/images/ubuntu-26.04-live-server-amd64.iso /mnt/isoimage

create /mnt/data/vm/ubuntu-26.04
create /mnt/data/vm/ubuntu-26.04/server

cd /mnt/data/vm/ubuntu-26.04/server
sudo cp /mnt/isoimage/casper/vmlinuz .
sudo cp /mnt/isoimage/casper/initrd .
sudo umount /mnt/isoimage

# create a VM called dev110 running ubuntu 26.04
# control-a c

sudo qemu-img create -f qcow2 /mnt/data/vm/boot/dev110.img 120G

as per middleware repo - nginx/qemu-9080/
copy dev110/ to ~/storage/qemu-9080/htdocs/ubuntu/
update passwd and packages in ~/storage/qemu-9080/htdocs/ubuntu/dev110/user-data
create password hash with: openssl passwd -6

sudo qemu-system-x86_64 \
  -boot d \
  -cdrom /mnt/data/vm/images/ubuntu-26.04-live-server-amd64.iso \
  -enable-kvm \
  -cpu kvm64 \
  -m 4096 \
  -nographic \
  -netdev bridge,id=hn0,br=virbr0 -device virtio-net-pci,netdev=hn0 \
  -drive file=/mnt/data/vm/boot/dev110.img,format=qcow2,if=virtio \
  -kernel /mnt/data/vm/ubuntu-26.04/server/vmlinuz \
  -initrd /mnt/data/vm/ubuntu-26.04/server/initrd \
  -append "console=ttyS0 boot=casper autoinstall auto=true apt-setup/proposed=true nomodeset fb=false priority=critical locale=en_US ds=nocloud-net;seedfrom=http://192.168.4.51:9080/ubuntu/dev110/" \
  -no-reboot

sudo qemu-system-x86_64 \
  -enable-kvm \
  -m 2048 \
  -drive file=/mnt/data/vm/boot/dev110.img,format=qcow2,if=virtio \
  -netdev bridge,id=hn0,br=virbr0 -device virtio-net-pci,netdev=hn0 \
  -nographic

